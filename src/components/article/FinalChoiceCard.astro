---
interface Props {
  productName: string;
  summary: string;
  ctaUrl: string;
  useCase?: string;
  lifestyleImage?: string;
}
const {
  productName,
  summary,
  ctaUrl,
  useCase,
  lifestyleImage = '/images/products/vitawild-lifestyle.jpg',
} = Astro.props;
const heading = useCase ? `Our #1 Choice for ${useCase}` : 'Our #1 Choice';
---

<section class="mt-16 bg-ink-primary text-surface-card rounded-2xl p-6 md:p-10">
  <div class="grid gap-6 md:gap-10 md:grid-cols-[minmax(0,5fr)_minmax(0,7fr)] items-center">
    <div class="rounded-xl overflow-hidden">
      <img
        src={lifestyleImage}
        alt={productName}
        class="w-full h-auto object-cover aspect-[3/2]"
        loading="lazy"
      />
    </div>

    <div class="min-w-0">
      <h2 class="font-heading font-bold text-[1.8rem] md:text-[2.4rem] leading-[1.15] tracking-[0.01em] text-surface-card mb-4">
        {heading}
      </h2>
      <p class="text-[1.05rem] md:text-[1.15rem] leading-[1.55] text-surface-card/85 mb-7">
        {summary}
      </p>
      <a
        href={ctaUrl}
        class="inline-flex items-center gap-2 bg-brand-orange text-ink-primary font-body font-black text-[1.2rem] md:text-[1.35rem] tracking-[0.05em] capitalize rounded-full px-7 py-3 no-underline hover:brightness-95 transition"
        rel="noopener"
      >
        Shop Now
        <span aria-hidden="true" class="text-[1.15em] leading-none">→</span>
      </a>
    </div>
  </div>
</section>
