---
import VisitSiteCTA from '../ranking/VisitSiteCTA.astro';

interface Props {
  productName: string;
  summary: string;
  ctaUrl: string;
  useCase?: string;
}
const { productName, summary, ctaUrl, useCase } = Astro.props;
const heading = useCase ? `My #1 Choice for ${useCase}` : 'My #1 Choice';
---

<section class="mt-12 bg-surface-card border border-border-card rounded-sm p-6 md:p-10">
  <h2 class="font-heading font-bold text-h2 mb-4">{heading}</h2>
  <h3 class="font-heading font-bold text-h3 mb-3">{productName}</h3>
  <p class="text-[1.2rem] leading-[1.6] mb-6">{summary}</p>
  <VisitSiteCTA href={ctaUrl}>Visit Site</VisitSiteCTA>
</section>
