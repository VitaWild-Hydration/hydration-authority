---
// "OUR #1 PICK!" — large orange pill with a black ribbon icon on the left.
// SVG-rendered so it scales cleanly and ships no static asset.
---

<div class="inline-flex items-center bg-brand-orange text-ink-primary rounded-full pl-3 pr-7 py-3 md:py-3.5 shadow-sm">
  <svg
    width="40"
    height="40"
    viewBox="0 0 40 40"
    aria-hidden="true"
    class="mr-3 shrink-0"
  >
    <path
      d="M7 5 L33 5 L33 35 L20 27 L7 35 Z"
      fill="#000000"
    />
    <path
      d="M14 13 L26 13 M14 18 L26 18 M14 23 L22 23"
      stroke="#FF9D00"
      stroke-width="1.8"
      stroke-linecap="round"
    />
  </svg>
  <span class="font-body font-black uppercase text-[1.1rem] md:text-[1.35rem] tracking-[0.06em] leading-none">
    Our #1 Pick!
  </span>
</div>
