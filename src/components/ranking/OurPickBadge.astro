---
// "OUR #1 PICK!" — orange pill with a black ribbon icon on the left.
// Sized to visually balance the brand-logo + score column on the right.
---

<div class="inline-flex items-center bg-brand-orange text-ink-primary rounded-full pl-2.5 pr-6 py-2.5 md:py-3 shadow-sm">
  <svg
    width="34"
    height="34"
    viewBox="0 0 34 34"
    aria-hidden="true"
    class="mr-2.5 shrink-0"
  >
    <path
      d="M6 4 L28 4 L28 30 L17 23 L6 30 Z"
      fill="#000000"
    />
    <path
      d="M11 11 L23 11 M11 15 L23 15 M11 19 L20 19"
      stroke="#FF9D00"
      stroke-width="1.6"
      stroke-linecap="round"
    />
  </svg>
  <span class="font-body font-black uppercase text-[1.05rem] md:text-[1.2rem] tracking-[0.06em] leading-none">
    Our #1 Pick!
  </span>
</div>
