---
// "OUR #1 PICK!" — orange pill with a black ribbon notch icon on the left.
// SVG-rendered so it scales cleanly and we never have to ship a static asset.
---

<div class="inline-flex items-center bg-brand-orange text-ink-primary rounded-full pl-2 pr-5 py-2 shadow-sm">
  <svg
    width="28"
    height="28"
    viewBox="0 0 28 28"
    aria-hidden="true"
    class="mr-2 shrink-0"
  >
    <path
      d="M5 4 L23 4 L23 24 L14 19 L5 24 Z"
      fill="#000000"
    />
    <path
      d="M9 9 L19 9 M9 13 L19 13"
      stroke="#FF9D00"
      stroke-width="1.5"
      stroke-linecap="round"
    />
  </svg>
  <span class="font-body font-black uppercase text-[0.95rem] md:text-[1.05rem] tracking-[0.06em]">
    Our #1 Pick!
  </span>
</div>
