---
interface Props {
  score: number;
  stars?: number;
}
const { score, stars = 5 } = Astro.props;
const formatted = Number.isInteger(score) ? `${score}.0` : score.toString();
const starsArray = Array.from({ length: stars });
---

<div class="flex flex-col items-end">
  <div class="font-heading font-bold text-brand-orange leading-none text-[2.4rem] md:text-[2.8rem]">
    {formatted}<span class="text-ink-muted/70 text-[1.4rem] md:text-[1.6rem] font-body font-normal">/10</span>
  </div>
  <div class="flex gap-0.5 mt-1" aria-label={`${stars} out of ${stars} stars`}>
    {starsArray.map(() => (
      <svg width="20" height="20" viewBox="0 0 24 24" aria-hidden="true">
        <path
          d="M12 2 L14.9 8.6 L22 9.3 L16.6 14.1 L18.2 21 L12 17.3 L5.8 21 L7.4 14.1 L2 9.3 L9.1 8.6 Z"
          fill="#FF9D00"
        />
      </svg>
    ))}
  </div>
</div>
