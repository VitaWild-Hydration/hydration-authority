---
interface Props {
  rank: number;
}
const { rank } = Astro.props;
---

<div class="inline-flex items-center justify-center w-16 h-16 md:w-[72px] md:h-[72px] rounded-full bg-ink-primary text-brand-orange font-heading font-bold text-[2rem] md:text-[2.25rem] leading-none shadow-sm">
  {rank}
</div>
