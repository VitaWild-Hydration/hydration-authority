---
interface Props {
  criterion: string;
  score: number;
  notes: string[];
}
const { criterion, score, notes } = Astro.props;
---

<div class="my-4">
  <p class="text-[1.15rem] md:text-[1.25rem] leading-[1.5]">
    <strong class="font-black">{criterion}:</strong> Rated <strong class="font-black text-brand-orange">{score}/10</strong>
  </p>
  {notes.length > 0 && (
    <ul class="list-disc pl-6 mt-2 space-y-1">
      {notes.map((n) => (
        <li class="text-[1.05rem] md:text-[1.15rem] leading-[1.55]">{n}</li>
      ))}
    </ul>
  )}
</div>
