---

<header class="bg-surface-card py-10 md:py-12 px-6 flex items-center justify-center">
  <a href="/" aria-label="Hydration Authority — home" class="inline-block">
    <picture>
      <source srcset="/images/logo/ha-horizontal.webp" type="image/webp" />
      <img
        src="/images/logo/ha-horizontal.png"
        alt="Hydration Authority"
        width="1100"
        height="200"
        class="h-12 md:h-16 w-auto"
        loading="eager"
        decoding="async"
      />
    </picture>
  </a>
</header>
